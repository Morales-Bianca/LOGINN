@{
    ViewData["Title"] = "Inicio";
}

<style>
    .dashboard-card {
        background: rgba(15, 23, 42, 0.85);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 1.2rem;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s;
        color: white;
        height: 100%;
    }
    .dashboard-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(59, 130, 246, 0.2);
        border-color: rgba(59, 130, 246, 0.4);
    }
    .dashboard-icon {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        font-size: 1.8rem;
    }
    .icon-blue { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .icon-green { background: rgba(16, 185, 129, 0.15); color: #10b981; }
    .icon-yellow { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
    .icon-purple { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; }
    .dashboard-card h5 {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }
    .dashboard-card p {
        color: rgba(255,255,255,0.5);
        font-size: 0.88rem;
        margin-bottom: 1.5rem;
    }
    .btn-card {
        border-radius: 2rem;
        padding: 0.4rem 1.4rem;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s;
        text-decoration: none;
    }
    .btn-blue { border: 1.5px solid #3b82f6; color: #3b82f6; background: transparent; }
    .btn-blue:hover { background: #3b82f6; color: white; }
    .btn-green { border: 1.5px solid #10b981; color: #10b981; background: transparent; }
    .btn-green:hover { background: #10b981; color: white; }
    .btn-yellow { border: 1.5px solid #f59e0b; color: #f59e0b; background: transparent; }
    .btn-yellow:hover { background: #f59e0b; color: white; }
    .btn-purple { border: 1.5px solid #8b5cf6; color: #8b5cf6; background: transparent; }
    .btn-purple:hover { background: #8b5cf6; color: white; }
    .welcome-banner {
        background: linear-gradient(135deg, rgba(59,130,246,0.2) 0%, rgba(139,92,246,0.2) 100%);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 1.2rem;
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        color: white;
    }
</style>

<div class="welcome-banner d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <h2 class="fw-bold mb-1">👋 ¡Bienvenido, @ViewBag.NombreUsuario!</h2>
        <p class="mb-0" style="color:rgba(255,255,255,0.6)">Gestiona tu inventario, visita la tienda y revisa tus pedidos.</p>
    </div>
    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm px-4 rounded-pill">
        <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
    </a>
</div>

<h5 class="text-white mb-3 fw-semibold"><i class="bi bi-grid me-2" style="color:#3b82f6"></i>Accesos Rápidos</h5>

<div class="row g-4">
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="dashboard-icon icon-blue">
                <i class="bi bi-box-seam"></i>
            </div>
            <h5>Inventario</h5>
            <p>Gestiona los productos, agrega nuevo stock, actualiza precios y descripciones.</p>
            <a asp-controller="ProductosView" asp-action="Index" class="btn-card btn-blue">Administrar →</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="dashboard-icon icon-green">
                <i class="bi bi-cart3"></i>
            </div>
            <h5>Tienda Virtual</h5>
            <p>Explora el catálogo, agrega productos al carrito y realiza compras simuladas.</p>
            <a asp-controller="Tienda" asp-action="Index" class="btn-card btn-green">Visitar Tienda →</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="dashboard-icon icon-yellow">
                <i class="bi bi-bag-check"></i>
            </div>
            <h5>Mis Pedidos</h5>
            <p>Revisa el historial de tus compras, facturas y el estado de tus pedidos recientes.</p>
            <a asp-controller="Tienda" asp-action="MisCompras" class="btn-card btn-yellow">Ver Historial →</a>
        </div>
    </div>
</div>
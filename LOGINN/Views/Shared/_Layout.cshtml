<!DOCTYPE html> 

<html lang="es"> 

<head> 

    <meta charset="utf-8" /> 

    <meta name="viewport" content="width=device-width, initial-scale=1.0" /> 

    <title>@ViewData["Title"] - Mi Inventario</title> 



    <!-- Bootstrap 5.3 (moderno) --> 

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" /> 



    <!-- Bootstrap Icons (para íconos bonitos) --> 

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" /> 



    <!-- Fuente moderna Inter --> 

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet"> 



    <!-- Estilos personalizados --> 

    <style> 
    * { 
        font-family: 'Inter', sans-serif; 
    } 

    body { 
        background: linear-gradient(135deg, #0a0f1e 0%, #0d1b3e 50%, #0a1628 100%);
        min-height: 100vh; 
        padding-bottom: 2rem; 
    } 

    .navbar { 
        background: rgba(13, 27, 62, 0.95) !important;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4); 
        border-bottom: 1px solid rgba(59, 130, 246, 0.2);
    } 

    .card-custom { 
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 1rem; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.3); 
        background: rgba(15, 23, 42, 0.9) !important;
        transition: transform 0.2s, box-shadow 0.2s; 
    } 

    .card-custom:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.2); 
        border-color: rgba(59, 130, 246, 0.4);
    } 

    .btn-custom-primary { 
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        border: none; 
        color: white; 
        border-radius: 2rem; 
        padding: 0.5rem 1.5rem; 
        transition: all 0.3s; 
    } 

    .btn-custom-primary:hover { 
        transform: scale(1.05); 
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.4); 
        color: white; 
    } 

    .table-modern { 
        border-radius: 1rem; 
        overflow: hidden; 
    } 

    .badge-stock { 
        padding: 0.5rem 1rem; 
        border-radius: 2rem; 
        font-weight: 500; 
    } 

    footer { 
        background: transparent; 
        color: rgba(255,255,255,0.4); 
        text-align: center; 
        margin-top: 3rem; 
    } 

    .card {
        background: rgba(15, 23, 42, 0.85) !important;
        border: 1px solid rgba(59, 130, 246, 0.15) !important;
        color: white !important;
    }

    .card-header {
        border-bottom: 1px solid rgba(59, 130, 246, 0.2) !important;
    }

    .form-control {
        background: rgba(255,255,255,0.05) !important;
        border: 1px solid rgba(59, 130, 246, 0.3) !important;
        color: white !important;
    }

    .form-control:focus {
        background: rgba(255,255,255,0.08) !important;
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.25) !important;
        color: white !important;
    }

    .table {
        color: rgba(255,255,255,0.85) !important;
    }

    .nav-link {
        color: rgba(255,255,255,0.7) !important;
        transition: color 0.2s;
    }

    .nav-link:hover {
        color: #3b82f6 !important;
    }
</style>

</head> 

<body> 

    <header> 

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark"> 

            <div class="container"> 

                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index"> 

                    <i class="bi bi-box-seam me-2"></i>Mi Inventario 

                </a> 

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"> 

                    <span class="navbar-toggler-icon"></span> 

                </button> 

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between"> 

                    <ul class="navbar-nav flex-grow-1"> 

                        <li class="nav-item"> 

                            <a class="nav-link" asp-controller="ProductosView" asp-action="Index"> 

                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>Productos 

                            </a> 

                        </li> 
                        <li class="nav-item"> 

    

</li>

                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))

                        { 
                            <li class="nav-item"> 
                                <a class="nav-link" asp-controller="Tienda" asp-action="Index"> 
                                    <i class="bi bi-shop me-1"></i>Tienda 
                                </a> 
                            </li>
                            <li class="nav-item"> 
                                <a class="nav-link" asp-controller="Tienda" asp-action="Carrito"> 
                                    <i class="bi bi-cart-fill me-1"></i>Carrito 
                                    @if (ViewBag.CarritoCount != null && ViewBag.CarritoCount > 0)
                                    {
                                        <span class="badge bg-danger">@ViewBag.CarritoCount</span>
                                    }
                                </a> 
                            </li>

                        } 

                    </ul> 

                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))

                    { 

                            <span class="navbar-text text-white-50"> 

                                <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre") 

                            </span> 

                    } 

                </div> 

            </div> 

        </nav> 

    </header> 



    <div class="container mt-4"> 

        <main role="main"> 

            @RenderBody() 

        </main> 

    </div> 



    <footer> 

        <div class="container"> 

            <small>© @DateTime.Now.Year - Mi Inventario Moderno</small> 

        </div> 

    </footer> 



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script> 

    @await RenderSectionAsync("Scripts", required: false) 

</body> 

</html> 
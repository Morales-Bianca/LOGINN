@model IEnumerable<LOGINN.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<style>
    .inv-card {
        background: rgba(15, 23, 42, 0.85);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 1.2rem;
        color: white;
    }
    .table { color: rgba(255,255,255,0.85); }
    .table thead th {
        color: rgba(255,255,255,0.4);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        font-weight: 600;
    }
    .table td { border-color: rgba(255,255,255,0.06); vertical-align: middle; }
    .table tbody tr:hover { background: rgba(59,130,246,0.05); }
    .badge-stock { padding: 0.35rem 0.85rem; border-radius: 2rem; font-size: 0.8rem; font-weight: 500; }
    .badge-sin { background: rgba(239,68,68,0.15); color: #ef4444; }
    .badge-bajo { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .badge-ok { background: rgba(16,185,129,0.15); color: #10b981; }
    .btn-outline-info { border-color: rgba(6,182,212,0.4); color: #06b6d4; }
    .btn-outline-info:hover { background: rgba(6,182,212,0.15); color: #06b6d4; }
    .btn-outline-warning { border-color: rgba(245,158,11,0.4); color: #f59e0b; }
    .btn-outline-warning:hover { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .btn-outline-danger { border-color: rgba(239,68,68,0.4); color: #ef4444; }
    .btn-outline-danger:hover { background: rgba(239,68,68,0.15); color: #ef4444; }
</style>

<div class="container mt-4">
    <div class="inv-card p-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <div>
                <h2 class="fw-bold mb-1">
                    <i class="bi bi-box-seam me-2" style="color:#3b82f6"></i>Mi Inventario
                </h2>
                <p class="mb-0" style="color:rgba(255,255,255,0.4);font-size:0.85rem">
                    <i class="bi bi-database me-1"></i>Total: @Model.Count() productos
                </p>
            </div>
            <a asp-action="Create" class="btn rounded-pill px-4" style="background:#3b82f6;color:white">
                <i class="bi bi-plus-circle me-2"></i>Nuevo Producto
            </a>
        </div>

        @if (TempData["Mensaje"] != null)
        {
                <div class="alert border-0 rounded-3 mb-4" style="background:rgba(16,185,129,0.15);color:#10b981">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]
                </div>
        }

        @if (!Model.Any())
        {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size:4rem;color:rgba(255,255,255,0.1)"></i>
                    <h4 class="mt-3" style="color:rgba(255,255,255,0.4)">No hay productos</h4>
                    <p style="color:rgba(255,255,255,0.3)">¡Comienza agregando tu primer producto!</p>
                    <a asp-action="Create" class="btn rounded-pill px-4 mt-2" style="background:#3b82f6;color:white">
                        <i class="bi bi-plus-circle me-2"></i>Agregar Producto
                    </a>
                </div>
        }
        else
        {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th class="d-none d-md-table-cell">Descripción</th>
                                <th class="text-center">Stock</th>
                                <th class="text-end">Precio</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                                    <tr>
                                        <td style="color:rgba(255,255,255,0.3);font-weight:600">#@item.Id</td>
                                        <td class="fw-semibold">@item.Nombre</td>
                                        <td class="d-none d-md-table-cell" style="color:rgba(255,255,255,0.4);font-size:0.88rem">
                                    @(item.Descripcion?.Length > 60 ? item.Descripcion.Substring(0, 60) + "..." : item.Descripcion ?? "—")
                                        </td>
                                        <td class="text-center">
                                    @if (item.Cantidad == 0)
                                    {
                                                    <span class="badge-stock badge-sin"><i class="bi bi-x-circle me-1"></i>Sin stock</span>
                                    }
                                    else if (item.Cantidad < 5)
                                    {
                                                    <span class="badge-stock badge-bajo"><i class="bi bi-exclamation-triangle me-1"></i>@item.Cantidad uds</span>
                                    }
                                    else
                                    {
                                                    <span class="badge-stock badge-ok"><i class="bi bi-check-circle me-1"></i>@item.Cantidad uds</span>
                                    }
                                        </td>
                                        <td class="text-end fw-bold fs-5" style="color:#3b82f6">
                                    @item.Precio.ToString("C")
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info rounded-start-3" title="Ver">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-end-3" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>
        }
    </div>
</div>
@model List<LOGINN.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<style>
    .carrito-card {
        background: rgba(15, 23, 42, 0.85);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 1.2rem;
        color: white;
    }
    .table { color: rgba(255,255,255,0.85); }
    .table thead th {
        color: rgba(255,255,255,0.5);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .table td { border-color: rgba(255,255,255,0.07); }
    .btn-outline-secondary {
        border-color: rgba(255,255,255,0.2);
        color: rgba(255,255,255,0.7);
    }
    .btn-outline-secondary:hover { background: rgba(255,255,255,0.1); color: white; }
    .btn-outline-danger { border-color: rgba(239,68,68,0.5); color: #ef4444; }
    .btn-outline-danger:hover { background: rgba(239,68,68,0.15); }
    .cantidad-input {
        background: rgba(255,255,255,0.05) !important;
        color: white !important;
        border-color: rgba(255,255,255,0.15) !important;
    }
    .empty-state { padding: 4rem 0; }
</style>

<div class="container mt-4">
    <div class="carrito-card p-4">
        <h2 class="fw-bold mb-4">
            <i class="bi bi-cart3 me-2" style="color:#3b82f6"></i>Mi Carrito
        </h2>

        @if (!Model.Any())
        {
                <div class="text-center empty-state">
                    <i class="bi bi-cart-x" style="font-size:4rem; color:rgba(255,255,255,0.15)"></i>
                    <h4 class="mt-3" style="color:rgba(255,255,255,0.5)">Tu carrito está vacío</h4>
                    <a asp-action="Index" class="btn mt-3 px-4 rounded-pill" style="background:#3b82f6; color:white">
                        <i class="bi bi-shop me-1"></i> Seguir comprando
                    </a>
                </div>
        }
        else
        {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div style="width:42px;height:42px;background:rgba(59,130,246,0.15);border-radius:0.6rem;display:flex;align-items:center;justify-content:center;">
                                                    <i class="bi bi-box-seam" style="color:#3b82f6"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@item.Producto?.Nombre</h6>
                                                    <small style="color:rgba(255,255,255,0.4)">Stock: @item.Producto?.Cantidad</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="input-group" style="width:120px;margin:0 auto;">
                                                <button class="btn btn-outline-secondary btn-minus" data-id="@item.Id">-</button>
                                                <input type="number" class="form-control text-center cantidad-input" data-id="@item.Id" value="@item.Cantidad" min="1" max="@item.Producto?.Cantidad" />
                                                <button class="btn btn-outline-secondary btn-plus" data-id="@item.Id">+</button>
                                            </div>
                                        </td>
                                        <td class="text-end">@item.Producto?.Precio.ToString("C")</td>
                                        <td class="text-end fw-bold subtotal" data-id="@item.Id" style="color:#3b82f6">
                                    @((item.Cantidad * (item.Producto?.Precio ?? 0)).ToString("C"))
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-danger btn-remove" data-id="@item.Id">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                        }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5" style="color:rgba(255,255,255,0.6)">Total:</td>
                                <td class="text-end fw-bold fs-4" style="color:#3b82f6" id="total">
                                @ViewBag.Total.ToString("C")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn rounded-pill px-4" style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7)">
                        <i class="bi bi-arrow-left me-1"></i> Seguir comprando
                    </a>
                    <a asp-action="Checkout" class="btn rounded-pill px-4" style="background:#3b82f6;color:white">
                        Proceder al pago <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        function actualizarItem(itemId, nuevaCantidad) {
            $.post('/Tienda/ActualizarCantidad', { itemId: itemId, cantidad: nuevaCantidad })
                .done(function(response) {
                    if (response.success) {
                        if (response.itemRemoved) { location.reload(); }
                        else {
                            $(`.subtotal[data-id='${itemId}']`).text('$' + response.subtotal.toFixed(2));
                            $('#total').text('$' + response.total.toFixed(2));
                        }
                    } else if (response.message) { alert(response.message); location.reload(); }
                });
        }
        $('.btn-plus').click(function() {
            var id = $(this).data('id');
            actualizarItem(id, parseInt($(`.cantidad-input[data-id='${id}']`).val()) + 1);
        });
        $('.btn-minus').click(function() {
            var id = $(this).data('id');
            actualizarItem(id, parseInt($(`.cantidad-input[data-id='${id}']`).val()) - 1);
        });
        $('.cantidad-input').change(function() {
            var id = $(this).data('id');
            var val = parseInt($(this).val());
            if (val > 0) actualizarItem(id, val);
        });
        $('.btn-remove').click(function() {
            if (confirm('¿Eliminar este producto?')) actualizarItem($(this).data('id'), 0);
        });
    });
</script>